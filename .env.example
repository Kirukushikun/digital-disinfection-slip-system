# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
APP_NAME=DDSS
APP_ENV=production              # local | staging | production
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file     # file | database
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12                # increase for stronger hashing (costs more CPU)

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # debug | info | notice | warning | error | critical

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DB_DUMP_BINARY_PATH=/usr/bin    # Windows example: C:\laragon\bin\mysql\mysql-8.0.30-winx64\bin
DB_CONNECTION=mysql
DB_HOST=127.0.0.1               # use service name (e.g. db) if running in Docker
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Logs Database Configuration
LOGS_DB_HOST=127.0.0.1          # can point to a separate DB server if needed
LOGS_DB_PORT=3306
LOGS_DB_DATABASE=your_logs_database_name
LOGS_DB_USERNAME=your_logs_db_user
LOGS_DB_PASSWORD=your_logs_db_password

# ─────────────────────────────────────────
# SESSION
# ─────────────────────────────────────────
SESSION_DRIVER=file             # file | cookie | database | redis
SESSION_LIFETIME=120            # minutes
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

# ─────────────────────────────────────────
# CACHE / QUEUE / BROADCAST
# ─────────────────────────────────────────
BROADCAST_CONNECTION=log        # log | pusher | ably | redis | null
FILESYSTEM_DISK=local           # local | public | s3
QUEUE_CONNECTION=database       # sync | database | redis | sqs
CACHE_STORE=redis               # database | redis | file | memcached
# CACHE_PREFIX=

# ─────────────────────────────────────────
# MEMCACHED (only if CACHE_STORE=memcached)
# ─────────────────────────────────────────
MEMCACHED_HOST=127.0.0.1

# ─────────────────────────────────────────
# REDIS (only if using redis for cache/queue)
# ─────────────────────────────────────────
REDIS_CLIENT=predis             # phpredis | predis
REDIS_HOST=127.0.0.1            # use service name (e.g. redis) if running in Docker
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────
MAIL_MAILER=log                 # smtp | mailgun | ses | postmark | sendmail | log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# AWS S3 (only if FILESYSTEM_DISK=s3)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────
# GOOGLE DRIVE — Spatie Backup
# ─────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_ID=         # OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_DRIVE_CLIENT_SECRET=     # OAuth 2.0 Client Secret
GOOGLE_DRIVE_REFRESH_TOKEN=     # Generate via OAuth playground or artisan command
GOOGLE_DRIVE_FOLDER="Your Backup Folder/SubFolder"

# ─────────────────────────────────────────
# VITE
# ─────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

